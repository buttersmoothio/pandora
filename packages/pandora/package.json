    "@mastra/cloudflare": "^1.2.0",
    "@mastra/cloudflare-d1": "^1.0.0",
    "@mastra/convex": "^1.0.3",
    "@mastra/core": "^1.4.0",
    "@mastra/dynamodb": "^1.0.0",
    "@mastra/lance": "^1.0.1",
    "@mastra/libsql": "^1.4.0",
    "@mastra/mongodb": "^1.3.1",
    "@mastra/mssql": "^1.1.0",
    "@mastra/pg": "^1.4.0",
    "@mastra/upstash": "^1.0.1",
    "cloudflare": "^4.5.0",
    "convex": "^1.31.7",
