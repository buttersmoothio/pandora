{
  "manifestVersion": 1,
  "id": "@pandorakit/exa-search",
  "name": "Exa Search",
  "description": "Search the web using the Exa API",
  "author": "Pandora",
  "version": "0.1.0",
  "license": "MIT",
  "homepage": "https://exa.ai",
  "repository": "https://github.com/mprasanjith/pandora/tree/master/packages/exa-search",
  "pandora": ">=0.0.1",
  "provides": {
    "tools": {
      "entry": "./src/index.ts",
      "sandbox": "compartment",
      "permissions": {
        "network": ["api.exa.ai"],
        "env": ["EXA_API_KEY"]
      }
    }
  },
  "envVars": [{ "name": "EXA_API_KEY" }]
}
