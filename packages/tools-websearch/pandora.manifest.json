{
  "manifestVersion": 1,
  "id": "tools-websearch",
  "name": "Web Search",
  "description": "Let your assistant search the web for up-to-date information",
  "author": "Pandora",
  "version": "0.1.0",
  "license": "MIT",
  "repository": "https://github.com/mprasanjith/pandora/tree/master/packages/tools-websearch",
  "pandora": ">=0.0.1",
  "provides": {
    "tools": {
      "entry": "./src/index.ts",
      "sandbox": "compartment",
      "permissions": {
        "network": ["api.search.brave.com", "api.tavily.com", "api.exa.ai", "api.perplexity.ai"],
        "env": ["TAVILY_API_KEY", "BRAVE_API_KEY", "EXA_API_KEY", "PERPLEXITY_API_KEY"]
      }
    }
  },
  "envVars": [
    { "name": "TAVILY_API_KEY", "required": false },
    { "name": "BRAVE_API_KEY", "required": false },
    { "name": "EXA_API_KEY", "required": false },
    { "name": "PERPLEXITY_API_KEY", "required": false }
  ],
  "configFields": [
    {
      "key": "searchBackend",
      "label": "Search Backend",
      "type": "enum",
      "description": "Which search service to use. Auto picks the best available option.",
      "options": [
        { "value": "auto", "label": "Auto-detect" },
        { "value": "tavily", "label": "Tavily" },
        { "value": "brave", "label": "Brave Search" },
        { "value": "exa", "label": "Exa" },
        { "value": "perplexity", "label": "Perplexity Search" }
      ]
    }
  ]
}
