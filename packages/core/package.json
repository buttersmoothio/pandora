{
  "name": "@pandora/core",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./storage": "./src/storage/exports.ts",
    "./tools": "./src/tools/exports.ts",
    "./channels": "./src/channels/exports.ts",
    "./agents": "./src/agents/exports.ts",
    "./manifest": "./src/manifest/index.ts"
  },
  "scripts": {
    "dev": "bun run serve.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@mastra/ai-sdk": "^1.0.4",
    "@mastra/core": "^1.4.0",
    "@mastra/libsql": "^1.4.0",
    "@mastra/memory": "^1.4.0",
    "ai": "^6.0.90",
    "hono": "^4.11.9",
    "@endo/compartment-mapper": "^2.0.0",
    "ses": "^1.14.0",
    "ts-blank-space": "^0.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260214.0",
    "@types/bun": "^1.3.9",
    "@vitest/coverage-istanbul": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
