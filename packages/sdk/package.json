{
  "name": "@pandorakit/sdk",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buttersmoothio/pandora.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    },
    "./channels": {
      "import": "./dist/channels.js",
      "types": "./dist/channels.d.ts"
    },
    "./agents": {
      "import": "./dist/agents.js",
      "types": "./dist/agents.d.ts"
    },
    "./schemas/pandora.manifest.schema.json": "./schemas/pandora.manifest.schema.json"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
