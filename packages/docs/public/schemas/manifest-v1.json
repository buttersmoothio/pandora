{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pandorakit.com/schemas/manifest-v1.json",
  "title": "Pandora Plugin Manifest",
  "description": "Schema for pandora.manifest.json plugin manifest files.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "manifestVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "homepage": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "pandora": {
      "type": "string",
      "pattern": "^[><=~^]"
    },
    "provides": {
      "type": "object",
      "properties": {
        "tools": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "entry": {
                  "type": "string"
                },
                "sandbox": {
                  "type": "string",
                  "enum": [
                    "compartment",
                    "host"
                  ]
                },
                "permissions": {
                  "type": "object",
                  "properties": {
                    "time": {
                      "type": "boolean"
                    },
                    "network": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "env": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "fs": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "random": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                },
                "requireApproval": {
                  "type": "boolean"
                }
              },
              "required": [
                "entry"
              ],
              "additionalProperties": false
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "entry": {
                    "type": "string"
                  },
                  "sandbox": {
                    "type": "string",
                    "enum": [
                      "compartment",
                      "host"
                    ]
                  },
                  "permissions": {
                    "type": "object",
                    "properties": {
                      "time": {
                        "type": "boolean"
                      },
                      "network": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "env": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "fs": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "random": {
                        "type": "boolean"
                      }
                    },
                    "additionalProperties": false
                  },
                  "requireApproval": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "entry"
                ],
                "additionalProperties": false
              }
            }
          ]
        },
        "agents": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "entry": {
                  "type": "string"
                },
                "useTools": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "modelTools": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "entry"
              ],
              "additionalProperties": false
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "entry": {
                    "type": "string"
                  },
                  "useTools": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "modelTools": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "entry"
                ],
                "additionalProperties": false
              }
            }
          ]
        },
        "channels": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "entry": {
                  "type": "string"
                },
                "sandbox": {
                  "type": "string",
                  "enum": [
                    "compartment",
                    "host"
                  ]
                },
                "permissions": {
                  "type": "object",
                  "properties": {
                    "time": {
                      "type": "boolean"
                    },
                    "network": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "env": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "fs": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "random": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                },
                "requireApproval": {
                  "type": "boolean"
                }
              },
              "required": [
                "entry"
              ],
              "additionalProperties": false
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "entry": {
                    "type": "string"
                  },
                  "sandbox": {
                    "type": "string",
                    "enum": [
                      "compartment",
                      "host"
                    ]
                  },
                  "permissions": {
                    "type": "object",
                    "properties": {
                      "time": {
                        "type": "boolean"
                      },
                      "network": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "env": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "fs": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "random": {
                        "type": "boolean"
                      }
                    },
                    "additionalProperties": false
                  },
                  "requireApproval": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "entry"
                ],
                "additionalProperties": false
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "envVars": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      }
    },
    "configFields": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "number",
              "password",
              "enum"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "placeholder": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "value",
                "label"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "key",
          "label",
          "type"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "manifestVersion",
    "id",
    "name",
    "pandora",
    "provides"
  ],
  "additionalProperties": false
}
