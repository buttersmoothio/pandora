{
  "manifestVersion": 1,
  "id": "storage-dynamodb",
  "name": "DynamoDB",
  "description": "Store conversations and settings in AWS DynamoDB",
  "author": "Pandora",
  "version": "0.1.0",
  "license": "MIT",
  "homepage": "https://aws.amazon.com/dynamodb",
  "repository": "https://github.com/mprasanjith/pandora/tree/master/packages/storage-dynamodb",
  "pandora": ">=0.0.1",
  "provides": {
    "storage": {
      "entry": "./src/index.ts",
      "sandbox": "host"
    }
  },
  "envVars": [
    { "name": "AWS_REGION" },
    { "name": "AWS_ACCESS_KEY_ID" },
    { "name": "AWS_SECRET_ACCESS_KEY" },
    { "name": "DYNAMODB_TABLE_NAME" }
  ]
}
