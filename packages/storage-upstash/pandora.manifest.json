{
  "manifestVersion": 1,
  "id": "storage-upstash",
  "name": "Upstash Redis",
  "description": "Store conversations and settings in Upstash Redis",
  "author": "Pandora",
  "version": "0.1.0",
  "license": "MIT",
  "homepage": "https://upstash.com",
  "repository": "https://github.com/mprasanjith/pandora/tree/master/packages/storage-upstash",
  "pandora": ">=0.0.1",
  "provides": {
    "storage": {
      "entry": "./src/index.ts",
      "sandbox": "host"
    }
  },
  "envVars": [{ "name": "UPSTASH_URL" }, { "name": "UPSTASH_TOKEN" }]
}
