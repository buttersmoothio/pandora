    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "@pandorakit/sdk": "workspace:*"
  },
  "devDependencies": {
    "@pandorakit/sdk": "workspace:*",
    "@types/hast": "^3.0.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
