{
  "name": "@pandorakit/telegram",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buttersmoothio/pandora.git",
    "directory": "packages/telegram"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
