{
  // JSON Schema for IDE autocompletion (optional but recommended)
  "$schema": "./config.schema.jsonc",

  "ai": {
    // Vercel AI Gateway - single API key for all providers
    // Get your key at: https://vercel.com/docs/ai-gateway
    "gateway": {
      "apiKey": "your-ai-gateway-api-key"
    },

    // Tool configurations - tools are auto-discovered from src/tools/
    // Just add config here to enable a tool
    "tools": {
      // No config needed - available to all agents
      "datetime": {},

      // Requires apiKey from https://tavily.com/
      // "tavilySearch": {
      //   "apiKey": "your-tavily-api-key"
      // }

      // To add a new tool:
      // 1. Create src/tools/my-tool.ts with a defineTool() call
      // 2. Add it here with any required config
      // That's it! No index files to edit.
    },

    // Agent configurations - use gateway model IDs like "provider/model-name"
    // Available providers: anthropic, openai, google, mistral, etc.
    // See: https://ai-sdk.dev/docs/getting-started/choosing-a-provider
    "agents": {
      // Main orchestrator - required
      "operator": {
        "model": "anthropic/claude-sonnet-4.5"
      }

      // Optional subagents - auto-discovered from src/subagents/
      // Uncomment to enable:

      // "coder": {
      //   "model": "anthropic/claude-sonnet-4.5"
      // },

      // "research": {
      //   "model": "openai/gpt-4o"
      // },

      // "webSearch": {
      //   "model": "openai/gpt-4o-mini-search-preview"
      // }

      // To add a custom subagent:
      // 1. Create src/subagents/my-agent.ts with a defineSubagent() call
      // 2. Add "myAgent": { "model": "..." } here
      // That's it! No index files to edit.
    }
  },

  // Log level: "normal" (default) or "verbose" (logs full model prompts and responses)
  // "logLevel": "verbose",

  // Message storage configuration
  // Storage backends are auto-discovered from src/store/
  "storage": {
    "type": "sqlite",
    "path": "data/pandora.db"
  },

  // Channel configurations
  // Channels are auto-discovered from src/channels/
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "your-telegram-bot-token",
      "ownerId": "your-telegram-user-id"
    }
  }
}
