{
  // Enable IDE autocompletion
  "$schema": "./config.schema.jsonc",

  "ai": {
    // Your Vercel AI Gateway key
    // Get one at: https://vercel.com/ai-gateway
    "gateway": {
      "apiKey": "your-ai-gateway-api-key"
    },

    // Tools give your AI extra capabilities
    // See docs/CONFIGURATION.md for all options
    "tools": {
      // Current date/time - no config needed
      "datetime": {}

      // Web search backends (choose one for webSearchTool agent):
      
      // Tavily - AI-powered search (get key at tavily.com)
      // "tavilySearch": {
      //   "apiKey": "your-tavily-api-key"
      // }
      
      // Exa - Advanced search with content extraction (get key at dashboard.exa.ai)
      // "exaSearch": {
      //   "apiKey": "your-exa-api-key"
      // }
      
      // Perplexity Search API (get key at perplexity.ai/account/api/keys)
      // "perplexitySearch": {
      //   "apiKey": "your-perplexity-api-key"
      // }
    },

    // AI agents - the brains of the operation
    // Models: anthropic/claude-sonnet-4.5, openai/gpt-4o, google/gemini-1.5-pro, etc.
    "agents": {
      // Main AI that handles your conversations (required)
      "operator": {
        "model": "anthropic/claude-sonnet-4.5"
      }

      // Specialists the operator can delegate to (optional)
      // Uncomment any you want:

      // "coder": {
      //   "model": "anthropic/claude-sonnet-4.5"
      // },

      // "research": {
      //   "model": "openai/gpt-4o"
      // },

      // Web search - choose ONE of these approaches:

      // Option 1: Native search (faster, no extra API cost)
      // Uses models with built-in search capabilities
      // "webSearchNative": {
      //   "model": "perplexity/sonar-pro"  // or "openai/gpt-4o-mini-search-preview"
      // }

      // Option 2: Tool-based search (works with any model)
      // Requires a search tool configured above (tavilySearch, exaSearch, or perplexitySearch)
      // "webSearchTool": {
      //   "model": "anthropic/claude-sonnet-4.5",  // Any model works
      //   "searchBackend": "tavilySearch"          // Which search tool to use
      // }
    }
  },

  // Where to save conversation history
  "storage": {
    "type": "sqlite",           // "sqlite" (persistent) or "memory" (temporary)
    "path": "data/pandora.db"   // Database file location
  },

  // Chat platforms (present in config = enabled)
  "channels": {
    "telegram": {
      "token": "your-telegram-bot-token",    // From @BotFather
      "ownerId": "your-telegram-user-id"     // From @userinfobot
    },
    "web": {
      "port": 3000,
      "token": "your-secret-auth-token"      // Clients must provide this to connect
    }
  }

  // Uncomment for detailed logging (shows full AI prompts/responses)
  // "logLevel": "verbose"
}
