{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pandora AI Agent Configuration",
  "description": "Configuration schema for the Pandora AI Agent",
  "type": "object",
  "required": ["ai"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE autocompletion"
    },
    "ai": {
      "type": "object",
      "required": ["providers", "agents"],
      "properties": {
        "providers": {
          "type": "object",
          "description": "AI provider configurations",
          "properties": {
            "openai": {
              "type": "object",
              "required": ["apiKey"],
              "properties": {
                "apiKey": {
                  "type": "string",
                  "description": "OpenAI API key"
                }
              },
              "additionalProperties": false
            },
            "anthropic": {
              "type": "object",
              "required": ["apiKey"],
              "properties": {
                "apiKey": {
                  "type": "string",
                  "description": "Anthropic API key"
                }
              },
              "additionalProperties": false
            },
            "minimax": {
              "type": "object",
              "required": ["apiKey"],
              "properties": {
                "apiKey": {
                  "type": "string",
                  "description": "MiniMax API key"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "tools": {
          "type": "object",
          "description": "Tool configurations. Add entries here to enable tools.",
          "additionalProperties": {
            "type": "object",
            "description": "Tool-specific configuration (e.g., API keys)"
          },
          "examples": [
            {
              "datetime": {},
              "tavilySearch": {
                "apiKey": "tvly-..."
              }
            }
          ]
        },
        "agents": {
          "type": "object",
          "description": "Agent configurations",
          "required": ["operator"],
          "properties": {
            "operator": {
              "type": "object",
              "description": "Main orchestrator agent - handles general conversation and delegates to subagents",
              "required": ["provider", "model"],
              "properties": {
                "provider": {
                  "type": "string",
                  "enum": ["openai", "anthropic", "minimax"],
                  "description": "AI provider for this agent"
                },
                "model": {
                  "type": "string",
                  "description": "Model name for this agent"
                },
                "description": {
                  "type": "string",
                  "description": "Optional description of this agent's role"
                }
              },
              "additionalProperties": false
            },
            "coder": {
              "type": "object",
              "description": "Specialized agent for coding tasks - activated when configured",
              "required": ["provider", "model"],
              "properties": {
                "provider": {
                  "type": "string",
                  "enum": ["openai", "anthropic", "minimax"],
                  "description": "AI provider for this agent"
                },
                "model": {
                  "type": "string",
                  "description": "Model name for this agent"
                },
                "description": {
                  "type": "string",
                  "description": "Optional description of this agent's role"
                }
              },
              "additionalProperties": false
            },
            "research": {
              "type": "object",
              "description": "Specialized agent for research tasks - activated when configured",
              "required": ["provider", "model"],
              "properties": {
                "provider": {
                  "type": "string",
                  "enum": ["openai", "anthropic", "minimax"],
                  "description": "AI provider for this agent"
                },
                "model": {
                  "type": "string",
                  "description": "Model name for this agent"
                },
                "description": {
                  "type": "string",
                  "description": "Optional description of this agent's role"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "channels": {
      "type": "object",
      "description": "Channel configurations",
      "properties": {
        "telegram": {
          "type": "object",
          "description": "Telegram channel configuration",
          "required": ["enabled", "token", "ownerId"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable or disable Telegram channel"
            },
            "token": {
              "type": "string",
              "description": "Telegram bot token from @BotFather"
            },
            "ownerId": {
              "type": "string",
              "description": "Telegram user ID of the bot owner (to authorize commands)"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "storage": {
      "type": "object",
      "description": "Message storage configuration",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["memory", "sqlite"],
          "description": "Storage backend type"
        },
        "path": {
          "type": "string",
          "description": "Path to SQLite database file (only for sqlite type)"
        }
      },
      "additionalProperties": false,
      "default": {
        "type": "sqlite",
        "path": "data/pandora.db"
      }
    },
    "logLevel": {
      "type": "string",
      "enum": ["normal", "verbose"],
      "default": "normal",
      "description": "Log level. 'normal' logs metadata (message flow, tool calls, durations). 'verbose' additionally logs full model prompts and responses."
    }
  },
  "additionalProperties": false
}
