{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pandora AI Agent Configuration",
  "description": "Configuration schema for the Pandora AI Agent. Agents, channels, and storage backends are auto-discovered at runtime.",
  "type": "object",
  "required": ["personality", "ai"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE autocompletion"
    },
    "personality": {
      "type": "string",
      "description": "Path to a markdown file that defines the agent's identity, personality traits, and communication style. The file contents are injected into the operator's system prompt.",
      "examples": ["personality.md", "config/personality.md"]
    },
    "ai": {
      "type": "object",
      "required": ["gateway", "agents"],
      "properties": {
        "gateway": {
          "type": "object",
          "description": "Vercel AI Gateway configuration",
          "required": ["apiKey"],
          "properties": {
            "apiKey": {
              "type": "string",
              "description": "Vercel AI Gateway API key"
            }
          },
          "additionalProperties": false
        },
        "tools": {
          "type": "object",
          "description": "Tool configurations. Add entries here to enable tools. Tools are auto-discovered from src/tools/.",
          "additionalProperties": {
            "type": "object",
            "description": "Tool-specific configuration (e.g., API keys)"
          },
          "examples": [
            {
              "datetime": {},
              "tavilySearch": { "apiKey": "tvly-..." },
              "exaSearch": { "apiKey": "exa-..." },
              "perplexitySearch": { "apiKey": "pplx-..." }
            }
          ]
        },
        "agents": {
          "type": "object",
          "description": "Agent configurations. Subagents are auto-discovered from src/subagents/. Add any subagent by name with a model.",
          "required": ["operator"],
          "properties": {
            "operator": {
              "$ref": "#/$defs/agentConfig",
              "description": "Main orchestrator agent - handles general conversation and delegates to subagents (required)"
            },
            // Built-in subagents (for IDE autocompletion)
            "coder": {
              "$ref": "#/$defs/agentConfig",
              "description": "Specialized agent for coding tasks"
            },
            "research": {
              "$ref": "#/$defs/agentConfig",
              "description": "Specialized agent for research tasks"
            },
            "webSearchNative": {
              "$ref": "#/$defs/agentConfig",
              "description": "Web search using models with built-in search (perplexity/sonar-pro, openai/gpt-4o-mini-search-preview, google/gemini-2.0-flash)"
            },
            "webSearchTool": {
              "$ref": "#/$defs/agentConfigWithSearchBackend",
              "description": "Web search using external search API (Tavily, Exa, Perplexity Search) - works with any model"
            }
          },
          // Allow any additional subagents
          "additionalProperties": {
            "$ref": "#/$defs/agentConfig"
          }
        }
      },
      "additionalProperties": false
    },
    "channels": {
      "type": "object",
      "description": "Channel configurations. Channels are auto-discovered from src/channels/.",
      "properties": {
        // Built-in channels (for IDE autocompletion)
        // A channel is enabled by being present in the config.
        "telegram": {
          "type": "object",
          "description": "Telegram channel. Present in config = enabled.",
          "properties": {
            "token": {
              "type": "string",
              "description": "Telegram bot token from @BotFather"
            },
            "ownerId": {
              "type": "string",
              "description": "Telegram user ID of the bot owner (for authorization)"
            }
          },
          "required": ["token", "ownerId"]
        },
        "web": {
          "type": "object",
          "description": "Web channel (HTTP + WebSocket API). Present in config = enabled.",
          "properties": {
            "port": {
              "type": "number",
              "description": "HTTP/WebSocket server port",
              "default": 3000
            },
            "token": {
              "type": "string",
              "description": "Auth token that clients must provide to connect"
            }
          },
          "required": ["token"]
        }
      },
      // Allow any additional channels
      "additionalProperties": {
        "type": "object",
        "description": "Channel-specific configuration. Present in config = enabled."
      }
    },
    "storage": {
      "type": "object",
      "description": "Message storage configuration. Storage backends are auto-discovered from src/store/.",
      "properties": {
        "type": {
          "type": "string",
          "description": "Storage backend type (e.g., 'memory', 'sqlite', or any registered backend)",
          "default": "sqlite",
          "examples": ["memory", "sqlite"]
        },
        "path": {
          "type": "string",
          "description": "Path to database file (for file-based backends like sqlite)",
          "default": "data/pandora.db"
        }
      },
      // Allow additional backend-specific properties
      "additionalProperties": true,
      "default": {
        "type": "sqlite",
        "path": "data/pandora.db"
      }
    },
    "memory": {
      "type": "object",
      "description": "Long-term memory configuration (optional). Enables episodic (automatic interaction logging) and semantic (agent-controlled facts/preferences) memory. SQLite provider uses hybrid search (vector similarity + BM25 keyword matching).",
      "properties": {
        "type": {
          "type": "string",
          "description": "Memory backend type",
          "default": "sqlite",
          "examples": ["sqlite"]
        },
        "path": {
          "type": "string",
          "description": "Path to memory database file (separate from conversation store)",
          "default": "data/memory.db"
        },
        "embeddingModel": {
          "type": "string",
          "description": "Gateway embedding model ID for vector embeddings",
          "default": "openai/text-embedding-3-small",
          "examples": [
            "openai/text-embedding-3-small",
            "openai/text-embedding-3-large",
            "openai/text-embedding-ada-002"
          ]
        }
      },
      // Allow additional provider-specific properties
      "additionalProperties": true
    },
    "logLevel": {
      "type": "string",
      "enum": ["normal", "verbose"],
      "default": "normal",
      "description": "Log level. 'normal' logs metadata (message flow, tool calls, durations). 'verbose' additionally logs full model prompts and responses."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "agentConfig": {
      "type": "object",
      "description": "Configuration for an agent (operator or subagent)",
      "required": ["model"],
      "properties": {
        "model": {
          "type": "string",
          "description": "Gateway model ID (e.g. anthropic/claude-sonnet-4.5, openai/gpt-4o)",
          "examples": [
            "anthropic/claude-sonnet-4.5",
            "openai/gpt-4o",
            "google/gemini-2.0-flash",
            "perplexity/sonar-pro",
            "openai/gpt-4o-mini-search-preview"
          ]
        }
      },
      "additionalProperties": false
    },
    "agentConfigWithSearchBackend": {
      "type": "object",
      "description": "Configuration for webSearchTool agent with search backend selection",
      "required": ["model", "searchBackend"],
      "properties": {
        "model": {
          "type": "string",
          "description": "Gateway model ID - can be any model (e.g. anthropic/claude-sonnet-4.5, openai/gpt-4o)",
          "examples": [
            "anthropic/claude-sonnet-4.5",
            "openai/gpt-4o",
            "google/gemini-2.0-flash"
          ]
        },
        "searchBackend": {
          "type": "string",
          "description": "Search backend tool to use (must be configured in ai.tools)",
          "examples": [
            "tavilySearch",
            "exaSearch",
            "perplexitySearch"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
