{
  "name": "pandora-monorepo",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage",
    "typecheck": "turbo typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "generate:schema": "bun run --cwd packages/core generate:schema",
    "changeset": "changeset",
    "version": "changeset version && bun update",
    "release": "bash ./scripts/publish.sh"
  },
  "overrides": {
    "mermaid": "11.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "tsup": "^8.5.1",
    "turbo": "^2.8.17"
  }
}
